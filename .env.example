# Copy to .env.local and fill in values.

# OpenAI (chat + Whisper STT) — preferred when set
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: reuse OPENAI_API_KEY for Whisper, or set WHISPER_STT_API_KEY separately
# WHISPER_STT_ENDPOINT=https://api.openai.com/v1
# WHISPER_STT_MODEL=whisper-1
# WHISPER_STT_API_KEY=

# Gemini API Key (voice assistant fallback at /assistant)
# Get one at https://aistudio.google.com/apikey
# On Vercel: Project → Settings → Environment Variables (all environments), then redeploy
GOOGLE_GENERATIVE_AI_API_KEY=
# Aliases also supported: GEMINI_API_KEY, GOOGLE_API_KEY
# Optional model overrides
# GEMINI_MODEL=gemini-3.1-flash-lite          # REST chat/STT (default)
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview  # Live API voice (WebSocket)

# --- Microsoft MAI-Transcribe (Azure Speech STT — recommended for production) ---
# Create a Speech resource: https://portal.azure.com → Azure AI Speech
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
#   Or Foundry Project endpoint: https://YOUR-RESOURCE.services.ai.azure.com
#   Do NOT use the Azure OpenAI endpoint (*.openai.azure.com) — that is for chat models only
# AZURE_SPEECH_REGION=eastus   # optional if endpoint is *.cognitiveservices.azure.com
# MAI_TRANSCRIBE_MODEL=mai-transcribe-1.5
# Optional domain terms (comma-separated) for hotel name, room types, etc.
# MAI_TRANSCRIBE_PHRASE_LIST=StayNep,Grand Plaza,Standard Room,Deluxe Suite

# --- Microsoft MAI-Voice (Azure Speech TTS — natural receptionist voice) ---
# Uses the same Speech resource as MAI-Transcribe
# MAI_VOICE_MODEL=mai-voice-2
# MAI_VOICE_NAME=en-US-Harper:MAI-Voice-2
# Or override TTS endpoint directly:
# MAI_VOICE_TTS_ENDPOINT=https://eastus.tts.speech.microsoft.com

# --- Self-hosted STT (Whisper — good fallback, accepts webm natively) ---
# Option A: local whisper-cpp (dev): run ./scripts/setup-local-whisper.sh
# WHISPER_MODEL_PATH=/Users/you/.local/share/whisper-cpp/ggml-base.en.bin
# Option B: Whisper HTTP server (Docker): docker compose -f docker-compose.whisper.yml up -d
# WHISPER_STT_ENDPOINT=http://127.0.0.1:8000/v1
# WHISPER_STT_MODEL=whisper-1
# WHISPER_STT_API_KEY=

# JWT signing secret — required on Vercel (min 32 chars). Generate: openssl rand -base64 32
JWT_SECRET=

# Optional: demo API key for unauthenticated AI access (send as x-demo-key or x-api-key header)
# DEMO_API_KEY=

# Optional: require guest sign-in for AI features in production (default: allow rate-limited anonymous)
# AI_REQUIRE_GUEST_AUTH=false

# Optional: Upstash Redis for distributed rate limiting on serverless (recommended in production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Prisma Postgres — linked via: npx prisma postgres link --database <id>
# DATABASE_URL is written to .env by the link command (never commit .env)

# TingTing SMS gateway (optional — escalation alerts)
# TINGTING_API_KEY=

# Public site URL for password-reset links in emails (recommended in production)
# Example: https://your-domain.com
NEXT_PUBLIC_APP_URL=

# Telephony webhook shared secret (generic/twilio webhook)
WEBHOOK_SECRET=

# Admin registration: set to "true" to allow /admin/register in production (default: disabled in prod)
# ALLOW_ADMIN_REGISTRATION=false

# Dev-only: seed admin@hotel.com / password123 when DB is empty (never use in production)
# SEED_DEFAULT_ADMIN=false

# ── Telnyx Programmable Voice ──────────────────────────────────────────────────
# Get your API key at https://portal.telnyx.com → Auth → API Keys
TELNYX_API_KEY=

# Ed25519 public key for verifying Telnyx webhook signatures (required in production)
# Found at https://portal.telnyx.com → Voice → TeXML Applications → your app → Signing Secret
TELNYX_PUBLIC_KEY=

# TTS voice string used in TeXML <Say> — choose any of:
#   Telnyx.NaturalHD          (best quality, default)
#   Telnyx.Natural            (budget, high volume)
#   Polly.Amy-Neural          (AWS Polly neural — female, en-GB)
#   Polly.Joanna-Neural       (AWS Polly neural — female, en-US)
#   Azure.en-US-EmmaNeural    (Azure Neural — female, en-US)
#   Azure.en-US-BrianMultilingualNeural  (Azure Neural HD — multilingual)
TELNYX_TTS_VOICE=Telnyx.NaturalHD

# Optional: mirror Telnyx payloads while debugging (disabled automatically in production)
# TELNYX_DEBUG_WEBHOOK_URL=https://webhook.site/your-inbox-id

# Optional: SMTP for escalation alerts, booking confirmations, and admin password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
