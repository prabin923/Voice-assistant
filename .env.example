# Copy to .env.local and fill in values.

# OpenAI (chat + Whisper STT) — preferred when set
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: reuse OPENAI_API_KEY for Whisper, or set WHISPER_STT_API_KEY separately
# WHISPER_STT_ENDPOINT=https://api.openai.com/v1
# WHISPER_STT_MODEL=whisper-1
# WHISPER_STT_API_KEY=

# Gemini API Key (voice assistant fallback at /assistant)
# Get one at https://aistudio.google.com/apikey
# On Vercel: Project → Settings → Environment Variables (all environments), then redeploy
GOOGLE_GENERATIVE_AI_API_KEY=
# Aliases also supported: GEMINI_API_KEY, GOOGLE_API_KEY
# Optional model overrides
# GEMINI_MODEL=gemini-3.1-flash-lite          # REST chat/STT (default)
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview  # Live API voice (WebSocket)

# --- Self-hosted STT (recommended — no Gemini quota for speech-to-text) ---
# Option A: local whisper-cpp (dev): run ./scripts/setup-local-whisper.sh
# WHISPER_MODEL_PATH=/Users/you/.local/share/whisper-cpp/ggml-base.en.bin
# Option B: Whisper HTTP server (Docker): docker compose -f docker-compose.whisper.yml up -d
# WHISPER_STT_ENDPOINT=http://127.0.0.1:8000/v1
# WHISPER_STT_MODEL=whisper-1
# WHISPER_STT_API_KEY=

# JWT signing secret — required on Vercel (min 8 chars). Generate: openssl rand -base64 32
JWT_SECRET=

# Public site URL for password-reset links in emails (recommended in production)
# Example: https://your-domain.com
NEXT_PUBLIC_APP_URL=

# Telephony webhook shared secret
WEBHOOK_SECRET=

# Optional: SMTP for escalation alerts and admin password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
